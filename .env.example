# ── POS & Agen Bisnis — Environment Variables ──
# Copy file ini ke .env.local untuk development
# cp .env.example .env.local

# ── AUTH_SECRET ────────────────────────────────────
# Secret untuk JWT token session. Wajib di production (min 32 chars).
# Di dev/test mode: jika kosong, otomatis pakai random per-process secret.
# Di production (Electron): otomatis di-generate per instalasi di userData/.auth-secret
#
# Untuk dev manual, generate dengan:
#   openssl rand -hex 48
# atau gunakan string acak minimal 32 karakter.
AUTH_SECRET=

# ── DATABASE_URL ───────────────────────────────────
# Path database SQLite. Default: file:./data.db
# Di production (Electron): otomatis di-set ke userData/pos-brilink.db
DATABASE_URL=file:./data.db

# ── NODE_ENV ───────────────────────────────────────
# Environment: development | production
# Next.js otomatis set ini, tidak perlu manual.
# NODE_ENV=development

# ── ELECTRON_DEV ───────────────────────────────────
# Set ke 1 untuk menjalankan Electron dalam mode dev (connect ke localhost:3000)
# ELECTRON_DEV=1

# ── PORT ───────────────────────────────────────────
# Port untuk Next.js dev server. Default: 3000
# Untuk E2E testing, Playwright otomatis set PORT=3001
# PORT=3000
