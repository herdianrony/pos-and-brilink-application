{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext", "dom"],
    "module": "commonjs",
    "allowJs": false,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "incremental": false,
    "outDir": "./electron/dist",
    "rootDir": "./electron",
    "sourceMap": true,
    "types": ["node", "electron"]
  },
  "include": [
    "electron/**/*.ts"
  ],
  "exclude": ["node_modules", "src", "electron/dist"]
}
