{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./src-tauri-ui/src/*"]
    }
  },
  "include": ["src-tauri-ui/**/*.ts", "src-tauri-ui/**/*.tsx"],
  "exclude": ["node_modules", "src-tauri/**/target/**"]
}
